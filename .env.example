# Anthropic (Claude) — análise visual de referências
ANTHROPIC_API_KEY=

# Replicate — geração de imagem com Flux 1.1 Pro (opcional se FAL_KEY configurada)
REPLICATE_API_TOKEN=

# Google AI Studio — Gemini (briefing, copies, imagens)
GOOGLE_API_KEY=

# Freepik AI — Mystic (imagens) + Kling (vídeos)
FREEPIK_API_KEY=

# FAL.AI — FLUX (imagens) + Kling v2.1 (vídeos text-to-video e image-to-video)
# Obtenha em: https://fal.ai/dashboard/keys
FAL_KEY=

# ElevenLabs — TTS locução em PT-BR
ELEVENLABS_API_KEY=

# Autenticação dos endpoints (recomendado em produção)
API_SECRET=
